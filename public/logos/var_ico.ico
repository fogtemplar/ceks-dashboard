n.prod.website-files.com/gsap/3.14.2/gsap.min.js" type="text/javascript"></script><script src="https://cdn.prod.website-files.com/gsap/3.14.2/TextPlugin.min.js" type="text/javascript"></script><script src="https://cdn.prod.website-files.com/gsap/3.14.2/SplitText.min.js" type="text/javascript"></script><script src="https://cdn.prod.website-files.com/gsap/3.14.2/Observer.min.js" type="text/javascript"></script><script type="text/javascript">gsap.registerPlugin(TextPlugin,SplitText,Observer);</script><script>
document.addEventListener("DOMContentLoaded", function () {
  const logoContainer = document.getElementById("logo-nav-video");
  if (!logoContainer) return;

  const video = logoContainer.querySelector("#nav-video video");
  if (!video) return;

  // Set playback behavior
  video.muted = true;
  video.autoplay = false;
  video.pause();

  // Play when hovering over the entire logo container
  logoContainer.addEventListener("mouseenter", () => {
    video.currentTime = 0; // restart each hover
    video.play();
  });

  // Pause + reset when leaving hover
  logoContainer.addEventListener("mouseleave", () => {
    video.pause();
    video.currentTime = 0;
  });
});
</script></body></html>